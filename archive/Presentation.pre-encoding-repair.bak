<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Presentation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #10111a;
  --white: #ffffff;
  --white-10: rgba(255, 255, 255, 0.1);
  --white-12: rgba(255, 255, 255, 0.12);
  --white-25: rgba(255, 255, 255, 0.25);
  --white-03: rgba(255, 255, 255, 0.03);
  --text-secondary: #9899af;
  --text-muted: #6b6c82;
  --accent: #cc004c;
  --primary: #5955f4;
  --nav-glass: rgba(16, 17, 26, 0.72);
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  --deck-width: 1920px;
  --deck-height: 1080px;
  --safe-x: 60px;
  --safe-top: 32px;
  --safe-bottom: 60px;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --dur-fast: 220ms;
  --dur-slow: 680ms;
  --font-display: "Bebas Neue", "Arial Narrow", sans-serif;
  --font-body: "Inter", system-ui, sans-serif;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  width: 100%;
  height: 100%;
  margin: 0;
  overflow: hidden;
  background: var(--bg);
  color: var(--white);
  font-family: var(--font-body);
}

button {
  font: inherit;
}

.presentation {
  position: fixed;
  inset: 0;
  overflow: hidden;
}

.deck {
  position: absolute;
  width: var(--deck-width);
  height: var(--deck-height);
  transform-origin: top left;
}

.slide {
  position: absolute;
  inset: 0;
  width: var(--deck-width);
  height: var(--deck-height);
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--dur-fast) ease;
}

.slide.active {
  opacity: 1;
  pointer-events: auto;
}

.slide-cover {
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(89, 85, 244, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(22, 23, 36, 0.28), rgba(16, 17, 26, 0.1)),
    var(--bg);
}

.grid-overlay {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.grid-overlay::before,
.grid-overlay::after {
  content: "";
  position: absolute;
  inset: 0;
}

.grid-overlay::before {
  background-image:
    linear-gradient(var(--white-03) 1px, transparent 1px),
    linear-gradient(90deg, var(--white-03) 1px, transparent 1px);
  background-size: 68px 68px;
  opacity: 0.9;
}

.grid-overlay::after {
  background:
    linear-gradient(90deg, rgba(16, 17, 26, 0.02) 0%, rgba(16, 17, 26, 0.08) 42%, rgba(16, 17, 26, 0.68) 76%, var(--bg) 100%),
    linear-gradient(180deg, rgba(16, 17, 26, 0.04) 0%, rgba(16, 17, 26, 0.02) 32%, rgba(16, 17, 26, 0.42) 68%, rgba(16, 17, 26, 0.86) 100%);
}

.progress-bar,
.bottom-cover {
  position: absolute;
  left: 0;
  height: 3px;
  z-index: 3;
}

.progress-bar {
  top: 0;
  width: 0;
  background: var(--accent);
  transition: width var(--dur-fast) var(--ease-out);
}

.bottom-cover {
  bottom: 0;
  width: 1280px;
  background: linear-gradient(90deg, var(--accent), rgba(204, 0, 76, 0));
}

.deck-ui {
  position: absolute;
  inset: 0;
  z-index: 12;
  pointer-events: none;
}

.top-meta,
.bottom-meta {
  position: absolute;
  left: var(--safe-x);
  width: calc(var(--deck-width) - (var(--safe-x) * 2));
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 2;
}


.top-meta {
  top: var(--safe-top);
}

.bottom-meta {
  bottom: var(--safe-bottom);
}

.deck-ui .nav {
  pointer-events: auto;
}

.page-title,
.count,
.brand-label,
.speaker-role,
.speaker-date {
  color: var(--text-secondary);
}

.page-title,
.count {
  font-size: 16px;
  line-height: 1.5;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
}

.brand-mark {
  width: 24px;
  height: 24px;
  display: block;
  object-fit: cover;
}

.brand-label {
  font-size: 20px;
  line-height: 1.5;
}

.deck-ui.ui-light-brand .brand-label {
  color: #3c3d54;
}

.count {
  display: flex;
  gap: 10px;
  color: var(--text-muted);
}

.hero {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 724px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 56px;
  transform: translate(-50%, calc(-50% + 54px));
  text-align: center;
  z-index: 2;
}

.hero-title {
  margin: 0;
  font-family: var(--font-display);
  font-size: 128px;
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -1.28px;
  text-transform: uppercase;
}

.hero-title .accent {
  color: var(--accent);
}

.hero-copy {
  width: 100%;
  margin: 0;
  color: var(--text-secondary);
  font-size: 16px;
  font-weight: 500;
  line-height: 1.5;
}

.hero-copy strong {
  color: var(--white);
  font-weight: 700;
}

.slide-about {
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(89, 85, 244, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(22, 23, 36, 0.28), rgba(16, 17, 26, 0.1)),
    var(--bg);
}

.about-left {
  position: absolute;
  left: 120px;
  top: 50%;
  width: 724px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 36px;
  transform: translateY(-50%);
  z-index: 2;
}

.about-kicker {
  display: flex;
  align-items: center;
  gap: 10px;
}

.about-kicker-line {
  width: 120px;
  height: 3px;
  background: var(--accent);
}

.about-kicker-text {
  color: var(--white);
  font-size: 14px;
  font-weight: 500;
  line-height: 1.65;
  letter-spacing: 1.12px;
  text-transform: uppercase;
}

.about-name {
  margin: 0;
  font-family: var(--font-display);
  font-size: 96px;
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.96px;
  text-transform: uppercase;
  white-space: nowrap;
}

.about-intro,
.about-body {
  margin: 0;
  color: var(--text-secondary);
}

.about-intro {
  width: 724px;
  font-size: 18px;
  font-weight: 500;
  line-height: 1.65;
}

.about-intro strong {
  color: var(--white);
  font-weight: 700;
}

.about-body {
  width: 724px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
}

.about-portrait-frame {
  position: absolute;
  left: 1166.5px;
  top: 316.47px;
  width: 350px;
  height: 442.06px;
  z-index: 2;
}

.about-portrait-art {
  position: absolute;
  left: -71.22px;
  top: -34.74px;
  width: 531.514px;
  height: 586.228px;
  object-fit: cover;
  object-position: center;
}

.about-roles {
  position: absolute;
  right: 120px;
  bottom: 140px;
  margin: 0;
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: 400;
  line-height: 1.65;
  letter-spacing: 0.66px;
  white-space: nowrap;
  z-index: 2;
}

.slide-agenda {
  background: var(--white);
  color: #10111a;
}

.agenda-light-side,
.agenda-dark-side {
  position: absolute;
  top: 0;
  bottom: 0;
}

.agenda-light-side {
  left: 0;
  width: 1260px;
  background:
    radial-gradient(circle at 8% 100%, rgba(204, 0, 76, 0.08), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.98)),
    var(--white);
  overflow: hidden;
}

.agenda-light-side::before,
.agenda-light-side::after {
  content: "";
  position: absolute;
  inset: 0;
}

.agenda-light-side::before {
  background-image:
    linear-gradient(rgba(89, 85, 244, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(89, 85, 244, 0.055) 1px, transparent 1px);
  background-size: 68px 68px;
}

.agenda-light-side::after {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
}

.agenda-dark-side {
  right: 0;
  width: 660px;
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(89, 85, 244, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(22, 23, 36, 0.28), rgba(16, 17, 26, 0.1)),
    var(--bg);
}

.agenda-header {
  position: absolute;
  left: 120px;
  top: 186px;
  width: 724px;
  display: flex;
  flex-direction: column;
  gap: 36px;
  z-index: 2;
}

.agenda-kicker {
  display: flex;
  align-items: center;
  gap: 10px;
}

.agenda-kicker-line {
  width: 120px;
  height: 3px;
  background: var(--accent);
}

.agenda-kicker-text {
  color: #10111a;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.65;
  letter-spacing: 1.12px;
  text-transform: uppercase;
}

.agenda-title {
  margin: 0;
  color: #10111a;
  font-family: var(--font-display);
  font-size: 80px;
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.8px;
  text-transform: uppercase;
  white-space: nowrap;
}

.agenda-list {
  position: absolute;
  left: 120px;
  top: 356px;
  width: 780px;
  display: flex;
  flex-direction: column;
  gap: 24px;
  z-index: 2;
}

.agenda-item {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 16px 20px;
  border-left: 4px solid #eeeeff;
}

.agenda-index {
  width: 60px;
  flex: 0 0 auto;
  color: var(--primary);
  font-family: var(--font-display);
  font-size: 48px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.48px;
}

.agenda-copy {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: 10px;
}

.agenda-item-title {
  margin: 0;
  color: #10111a;
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.28px;
  text-transform: uppercase;
}

.agenda-item-text {
  margin: 0;
  color: #3c3d54;
  font-size: 18px;
  line-height: 1.7;
}

.question-card {
  position: absolute;
  top: 309px;
  right: 120px;
  width: 420px;
  padding: 16px;
  border-top: 4px solid var(--accent);
  z-index: 2;
}

.question-mark {
  margin: 0 0 20px;
  color: var(--primary);
  font-family: var(--font-display);
  font-size: 56px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.56px;
}

.question-title {
  margin: 0 0 20px;
  color: var(--accent);
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.28px;
  text-transform: uppercase;
}

.question-list {
  margin: 0;
  padding-left: 24px;
  color: var(--text-secondary);
  font-size: 16px;
  font-weight: 500;
  line-height: 1.5;
}

.question-list li + li {
  margin-top: 18px;
}

.slide-dark-grid {
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(89, 85, 244, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(22, 23, 36, 0.28), rgba(16, 17, 26, 0.1)),
    var(--bg);
}

.light-grid-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background:
    radial-gradient(circle at 8% 100%, rgba(204, 0, 76, 0.06), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.98)),
    var(--white);
}

.light-grid-bg::before,
.light-grid-bg::after {
  content: "";
  position: absolute;
  inset: 0;
}

.light-grid-bg::before {
  background-image:
    linear-gradient(rgba(89, 85, 244, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(89, 85, 244, 0.055) 1px, transparent 1px);
  background-size: 68px 68px;
}

.light-grid-bg::after {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
}

.slide-ai-definition .grid-overlay::after,
.slide-gaia-demo .grid-overlay::after,
.slide-smartbricks-demo .grid-overlay::after,
.slide-questions .grid-overlay::after,
.slide-thanks .grid-overlay::after {
  background:
    linear-gradient(90deg, rgba(16, 17, 26, 0.02) 0%, rgba(16, 17, 26, 0.06) 40%, rgba(16, 17, 26, 0.42) 72%, rgba(16, 17, 26, 0.84) 100%),
    linear-gradient(180deg, rgba(16, 17, 26, 0.04) 0%, rgba(16, 17, 26, 0.02) 32%, rgba(16, 17, 26, 0.24) 68%, rgba(16, 17, 26, 0.74) 100%);
}

.section-overline,
.walkthrough-overline {
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-overline-line,
.walkthrough-overline-line {
  width: 120px;
  height: 3px;
  background: var(--accent);
}

.section-overline-text,
.walkthrough-overline-text {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.65;
  letter-spacing: 1.12px;
  text-transform: uppercase;
}

.section-overline-text {
  color: #10111a;
}

.walkthrough-overline-text {
  color: var(--white);
}

.slide-ai-definition .section-overline-text {
  color: var(--white);
}

.slide-intro-light {
  background: var(--white);
  color: #10111a;
}

.intro-title-block {
  position: absolute;
  left: 120px;
  top: 180px;
  width: 540px;
  display: flex;
  flex-direction: column;
  gap: 36px;
  z-index: 2;
}

.intro-title {
  margin: 0;
  color: #10111a;
  font-family: var(--font-display);
  font-size: 80px;
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.8px;
  text-transform: uppercase;
  white-space: nowrap;
}

.intro-copy-stack {
  position: absolute;
  left: 120px;
  top: 350px;
  width: 540px;
  display: flex;
  flex-direction: column;
  gap: 30px;
  z-index: 2;
}

.intro-lead,
.intro-body {
  margin: 0;
  color: #3c3d54;
}

.intro-lead {
  font-size: 18px;
  font-weight: 500;
  line-height: 1.65;
}

.intro-body {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
  width: 100%;
}

.info-card {
  border: 1px solid #eeeeff;
  border-radius: 16px;
  background: var(--white);
  padding: 16px 14px;
}

.info-card.half {
  width: 254px;
}

.info-card.full {
  width: 100%;
}

.info-label {
  margin: 0 0 16px;
  color: #6b6c82;
  font-size: 11px;
  font-weight: 500;
  line-height: 1.65;
  letter-spacing: 0.44px;
  text-transform: uppercase;
}

.info-value {
  margin: 0;
  color: #10111a;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.5;
}

.intro-hero-frame {
  position: absolute;
  top: 180px;
  right: -120px;
  width: 1320px;
  height: 720px;
  border: 10px solid rgba(187, 213, 234, 0.3);
  border-radius: 32px;
  overflow: hidden;
  z-index: 2;
}

.intro-hero-frame.narrow {
  right: -80px;
  width: 1280px;
}

.intro-hero-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.slide-gaia-intro .intro-hero-frame {
  background: linear-gradient(180deg, #dbe3eb 0%, #d7e1eb 100%);
}

.slide-gaia-intro .intro-hero-frame img {
  object-fit: cover;
  object-position: center center;
}

.slide-gaia-walkthrough .walkthrough-main {
  gap: 44px;
}

.slide-gaia-walkthrough .walkthrough-main-body {
  gap: 40px;
}

.slide-gaia-walkthrough .walk-step {
  gap: 24px;
}

.slide-gaia-walkthrough .walkthrough-sidebar.w600 {
  padding: 228px 120px;
}

.slide-gaia-walkthrough .walkthrough-sidebar-stack {
  gap: 40px;
}

.slide-gaia-walkthrough .side-card {
  padding: 20px;
  gap: 20px;
}

.walkthrough-main {
  position: absolute;
  left: 120px;
  top: 120px;
  width: 540px;
  display: flex;
  flex-direction: column;
  gap: 36px;
  z-index: 2;
}

.walkthrough-heading {
  margin: 0;
  color: #10111a;
  font-family: var(--font-display);
  font-size: 80px;
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.8px;
  text-transform: uppercase;
  white-space: nowrap;
}

.walkthrough-main-body {
  position: absolute;
  left: 120px;
  top: 290px;
  width: 1020px;
  display: flex;
  flex-direction: column;
  gap: 30px;
  z-index: 2;
}

.walkthrough-main-body.narrow {
  top: 190px;
  width: 540px;
}

.walk-step {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.walk-step-head {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.walk-step-index {
  width: 60px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  flex: 0 0 auto;
}

.walk-step-index span {
  color: #9899af;
  font-family: var(--font-display);
  font-size: 56px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.56px;
}

.walk-step-index .line {
  width: 120px;
  height: 3px;
  background: var(--primary);
}

.walk-step-title-wrap {
  padding-top: 16px;
}

.walk-step-title {
  margin: 0;
  color: #10111a;
  font-family: var(--font-display);
  font-size: 36px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.36px;
  text-transform: uppercase;
}

.walk-step-copy,
.walk-step-list,
.walk-step-list ul {
  margin: 0;
  color: #3c3d54;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
}

.walk-step-list,
.walk-step-list ul {
  padding-left: 24px;
}

.walk-step-list ul {
  padding-left: 24px;
  margin-top: 0;
}

.walk-step-list li + li {
  margin-top: 2px;
}

.walkthrough-sidebar {
  position: absolute;
  top: 0;
  right: 0;
  height: 1080px;
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(89, 85, 244, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(22, 23, 36, 0.28), rgba(16, 17, 26, 0.1)),
    var(--bg);
  z-index: 1;
}

.walkthrough-sidebar.w600 {
  width: 600px;
  padding: 212px 110px;
}

.walkthrough-sidebar.w900 {
  width: 900px;
  padding: 104px;
}

.walkthrough-sidebar.w1140 {
  width: 1140px;
  padding: 104px;
}

.walkthrough-sidebar-stack {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.walkthrough-sidebar-stack.gap-52 {
  gap: 40px;
}

.side-card {
  border-top: 4px solid var(--accent);
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.side-card.quote-large .quote-mark {
  line-height: 0.3;
}

.quote-mark {
  margin: 0;
  color: var(--primary);
  font-family: var(--font-display);
  font-size: 56px;
  font-weight: 400;
  line-height: 0.3;
  letter-spacing: 0.56px;
}

.side-card-title {
  margin: 0;
  color: var(--accent);
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0.28px;
  text-transform: uppercase;
}

.side-card-copy,
.side-card-list {
  margin: 0;
  color: var(--text-secondary);
  font-size: 16px;
  font-weight: 500;
  line-height: 1.5;
}

.side-card-list {
  padding-left: 24px;
}

.side-card-list li + li {
  margin-top: 2px;
}

.slide-demo {
  background:
    radial-gradient(circle at 12% 102%, rgba(204, 0, 76, 0.12), transparent 34%),
